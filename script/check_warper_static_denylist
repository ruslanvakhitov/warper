#!/usr/bin/env bash

set -euo pipefail
cd "$(dirname "$0")/.."

if ! command -v rg >/dev/null 2>&1; then
    echo "ripgrep is required to run the WARPER-001 static denylist check."
    exit 1
fi

scope="${1:-startup}"

endpoint_denylist='(app\.warp\.dev|rtc\.app\.warp\.dev|sessions\.app\.warp\.dev|oz\.warp\.dev|AIza[0-9A-Za-z_-]+|identitytoolkit\.googleapis\.com|securetoken\.googleapis\.com|firebaseapp\.com|rudderstack\.com|rudderlabs|api\.segment\.io|dataplane\.rudderstack|sentry\.io|releases\.warp\.dev|warp-releases|channel_versions\.json|warp\.dev/download|/download/cli)'

common_excluded_globs=(
    --glob '!specs/**'
    --glob '!script/**'
    --glob '!**/*_test.rs'
    --glob '!**/*_tests.rs'
    --glob '!**/mod_test.rs'
    --glob '!**/lib_tests.rs'
    --glob '!**/tests/**'
    --glob '!crates/warp_graphql_schema/**'
    --glob '!**/generated/**'
    --glob '!**/generated_schema/**'
    --glob '!app/src/ai/agent/api/openrouter.rs'
)

run_denylist() {
    local label="$1"
    local denylist="$2"
    shift 2

    local matches
    matches="$(
        rg \
            --line-number \
            --no-heading \
            --color never \
            "${common_excluded_globs[@]}" \
            "$@" \
            -e "$denylist" || true
    )"

    if [[ -n "$matches" ]]; then
        echo "WARPER-001 static denylist failed for scope '$scope' ($label)."
        echo "Remove hosted Warp/Oz/account/billing/Drive/team/sharing/agent/telemetry/update entrypoints from runtime code."
        echo
        echo "$matches"
        exit 1
    fi
}

case "$scope" in
    startup)
        targets=(
            "app/src/bin/oss.rs"
            "app/src/lib.rs"
            "app/src/settings/ai_tests.rs"
            "crates/integration/src/bin/integration.rs"
            "crates/warp_core/src/channel"
        )
        excluded_globs=()
        ;;
    entrypoints)
        ;;
    all-runtime)
        targets=(
            "app/src"
            "crates"
        )
        excluded_globs=()
        ;;
    -h|--help)
        cat <<'USAGE'
Usage: script/check_warper_static_denylist [startup|entrypoints|telemetry-crash-update|all-runtime]

Checks WARPER-001 local-only guardrails for removed hosted endpoint literals,
hosted update/download paths, and high-risk UI/action/deeplink entrypoint
roots. OpenRouter files are not scanned by the entrypoint symbol checks because
OpenRouter is explicitly out of scope for WARPER-001 amputation.

All modes exclude specs, scripts, tests, generated schema, generated files, and
OpenRouter implementation files from the scanned runtime surface.

Modes:
  startup                 Check the local startup/channel/config surfaces used by Warper.
  entrypoints             Check removed UI/action/deeplink/restore/menu roots for hosted surfaces.
  telemetry-crash-update  Check telemetry, crash reporting, autoupdate, and Sentry build hooks.
  all-runtime             Check app/src and crates, excluding explicitly scoped test files.
USAGE
        exit 0
        ;;
    telemetry-crash-update|worker-d)
        targets=(
            "app/src/server/telemetry"
            "app/src/crash_reporting"
            "app/src/autoupdate"
            "app/src/appearance.rs"
            "app/build.rs"
        )
        excluded_globs=()
        ;;
    *)
        echo "Unknown scope: $scope"
        echo "Run script/check_warper_static_denylist --help for usage."
        exit 2
        ;;
esac

if [[ "$scope" == "entrypoints" ]]; then
    run_denylist \
        "workspace hosted actions" \
        '\b(LogOut|Reauth|SignupAnonymousUser|SignInAnonymousWebUser|ExportAllWarpDriveObjects|ImportToTeamDrive|ToggleWarpDrive|OpenWarpDrive|AttemptLoginGatedAIUpgrade|OpenBillingAndUsagePage|OpenBillingPortal|OpenTeamSettingsPage|JoinSharedSession|StartSharedSession|OpenShareSessionModal)\b' \
        app/src/workspace/action.rs \
        app/src/workspace/global_actions.rs \
        app/src/app_menus.rs

    run_denylist \
        "settings hosted pages and labels" \
        '(billing_and_usage|warp_drive_page|teams_page|referrals_page|platform_page|telemetry\.rs|Billing and Usage|Warp Drive as agent context|Auto-sync plans to Warp Drive|Team settings|Computer use in Cloud Agents|CloudAgentComputerUseWidget|ToggleCloudAgentComputerUse|ToggleWarpDriveContext|SignupAnonymousUser|OpenBillingPortal)' \
        app/src/settings \
        app/src/settings_view

    run_denylist \
        "command/search/menu hosted labels" \
        '(Share session|Stop sharing|Shared session|Warp Drive|Billing|Pricing|Quota|team drive|Team Drive|Open in Oz|Cloud Agent|cloud-agent|create-environment|remote-control)' \
        app/src/search \
        app/src/terminal/input \
        app/src/pane_group/pane/view/header

    run_denylist \
        "restore/deeplink hosted roots" \
        '(SharedSession|shared_session|AmbientAgentPaneSnapshot|CloudMode|CloudConversationData::Oz|OpenWarpDriveObjectSettings|SignupAnonymousUser|OpenWarpDriveObjectInPane)' \
        app/src/app_state.rs \
        app/src/tab.rs \
        app/src/pane_group/mod.rs \
        app/src/pane_group/pane \
        app/src/terminal/view/action.rs

    run_denylist \
        "deeplink hosted dispatches" \
        '(root_view:open_(team|billing|platform|environment|warp_drive|shared|auth)|WorkspaceAction::(OpenWarpDrive|ToggleWarpDrive|ImportToTeamDrive|ExportAllWarpDriveObjects|SignupAnonymousUser|Reauth|LogOut)|://(auth|team|conversation|drive|shared_session)/|settings/(billing_and_usage|teams|environments|platform))' \
        app/src/uri

    run_denylist \
        "removed URI host/path roots" \
        '(UriHost::(Auth|Billing|Team|Drive|WarpDrive|SharedSession|Environment)|Self::(Auth|Billing|Team|Drive|WarpDrive|SharedSession|Environment)|"(auth|billing|team|teams|drive|warp_drive|shared_session|environment|environments)" => Ok\(Self::|"/(auth|billing|team|teams|drive|warp-drive|warp_drive|shared-session|shared_session|environment|environments|create-environment)|settings/(account|billing_and_usage|teams|team|environments|platform|warp_drive)|root_view:open_(auth|login|billing|team|environment|warp_drive|shared|drive))' \
        app/src/uri \
        app/src/workspace/action.rs \
        app/src/workspace/global_actions.rs \
        app/src/app_state.rs \
        app/src/pane_group/mod.rs \
        app/src/pane_group/pane \
        app/src/terminal/view/action.rs

    echo "WARPER-001 static denylist passed for scope '$scope'."
    exit 0
fi

denylist="$endpoint_denylist"

if [[ "$scope" == "telemetry-crash-update" || "$scope" == "worker-d" ]]; then
    denylist="(${denylist#(}"
    denylist="${denylist%)}|sentry::init|sentry::capture_message|startSentry|stopSentry|crashSentry|recordBreadcrumb|setUser\(|Sentry\.framework|Sentry\.xcframework|Sentry-Dynamic|update_sentry_cocoa|warp_sentry_objc)"
fi

run_denylist \
    "hosted endpoint literals" \
    "$denylist" \
    ${excluded_globs[@]+"${excluded_globs[@]}"} \
    "${targets[@]}"

echo "WARPER-001 static denylist passed for scope '$scope'."
